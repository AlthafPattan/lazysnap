{
  "name": "@lazysnap/angular",
  "version": "0.1.0",
  "description": "Angular wrapper for @lazysnap/core — lazy image loading with observability, blur-up, and LQIP",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "keywords": [
    "angular",
    "lazy-loading",
    "images",
    "lqip",
    "blur-up",
    "observability",
    "angular-universal",
    "performance"
  ],
  "author": "Althaf Khan Pattan",
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": ">=15.0.0",
    "@angular/core": ">=15.0.0"
  },
  "dependencies": {
    "@lazysnap/core": "file:../core"
  },
  "devDependencies": {
    "@angular/common": "^17.3.0",
    "@angular/core": "^17.3.0",
    "typescript": "^5.4.5"
  }
}
